<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style rel="stylesheet" href="/stylesheets/style.css"></style>
    <script src="https://cdn.tailwindcss.com"></script>

</head>
<body>
    <div class="main w-full min-h-screen bg-rounded bg-zinc-800 p-8 backdrop-grayscale">
        <h1 class="text-4xl font-bold text-teal-500">Notes App Maker</h1>
        <div class="form py-10 ">
            <form action="/create" method="post">
                <input class="block w-full rounded-lg px-5 py-3 border mt-2 border-yellow-200 bg-gray-600 " type="text" placeholder="Title goes here" name="title">
                <textarea class="block w-full rounded-lg px-5 py-3 bg-gray-600 resize-none mt-2 border border-yellow-200 " placeholder="Enter your task details?" name="details"></textarea>
                <input type="submit" class="text-white font-semibold text-xl bg-blue-600 mt-3 rounded-lg px-5 py-1 hover:bg-red-600" value="Create Task">
            </form>
        </div>
        <div class="tasks flex flex-row gap-3 flex-wrap">
            <% if(files.length>0){%>
            
            <% files.forEach(function(val){ %>
                 <div class=" task min-w-85 bg-gray-600 px-3 py-4 rounded-lg ">
                <h1 class="text-white text-3xl tracking-tighter"><%= val %></h1>
                <a class="text-blue-600 mt-2 inline-block" href="./files/<%=val%>">Read more.</a>
            </div>
           
            <%})%>
            <% } else{ %>
                <h2 class="text-xl text-white">No tasks yet</h2>
            <%}%>
        </div>
    <script src="/javascripts/script.js"></script>
</body>
</html>