<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Note Maker</title>
    <style rel="stylesheet" href="/stylesheets/style.css"></style>
    <script src="https://cdn.tailwindcss.com"></script>

</head>
<body>
    <div class="main w-full min-h-screen bg-rounded bg-zinc-800 p-10">
        <a href="/" class="text-[18px] font-semibold text-blue-500 inline-block mb-8">Go back to home</a>
        <h1 class="text-3xl font-bold text-teal-500 mb-10">Edit file Name</h1>
    <form action="/edit" method="post">
                <input class="block w-1/3 rounded-lg px-5 py-3 border mt-2 border-yellow-200 bg-gray-600 text-zinc-400"  type="text" placeholder="Previous Name" type="hidden" name="previous" value="<%=filename%>">
                <input class="block w-1/3 rounded-lg px-5 py-3 bg-gray-600 resize-none mt-2 border border-yellow-200 text-white" placeholder="New Name" name="newName"></textarea>
                <input type="submit" class="text-white font-semibold text-xl bg-yellow-600 mt-3 rounded-lg px-5 py-1 hover:bg-red-600" value="Update Name">
            </form>
    </div>

</body>
</html>